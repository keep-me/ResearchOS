# 前端开发环境变量示例
# 说明：
# 1. 本文件主要用于 vite 本地开发
# 2. 当前项目默认通过 VITE_PROXY_TARGET 把 /api 代理到后端
# 3. Docker / nginx 生产部署通常不需要这个文件

# 本地开发端口
VITE_PORT=3002

# 本地开发时，把 /api 转发到后端
VITE_PROXY_TARGET=http://127.0.0.1:8002

# 如需显式设置 HMR，可按需取消注释
# VITE_HMR_HOST=127.0.0.1
# VITE_HMR_PORT=3002

# 如在 Docker Desktop / WSL / 远端文件系统上开发，可按需启用轮询
# VITE_USE_POLLING=true
# VITE_POLL_INTERVAL=300
