APP_ENV=dev
APP_NAME=ResearchOS API
API_HOST=0.0.0.0
API_PORT=8002
SITE_URL=http://127.0.0.1:3002
# Docker Compose 默认仅监听本机；如需公网暴露，先完成生产认证配置。
BACKEND_PORT_BIND=127.0.0.1:8002
FRONTEND_PORT_BIND=127.0.0.1:3002

# Docker 基础镜像源（默认 docker.io）
# 如 Docker Hub 网络不稳定，可改为: docker.m.daocloud.io
BASE_REGISTRY=docker.io
APT_MIRROR=
NPM_REGISTRY=https://registry.npmjs.org

DATABASE_URL=sqlite:///./data/researchos.db

PDF_STORAGE_ROOT=./data/papers
BRIEF_OUTPUT_ROOT=./data/briefs
AUTOMATION_ALLOWED_ROOTS=./data,./tmp
# 图表提取模式: arxiv_source / mineru
FIGURE_EXTRACT_MODE=arxiv_source
MINERU_BACKEND=api
MINERU_API_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_API_MODEL_VERSION=vlm
MINERU_API_POLL_INTERVAL_SECONDS=3
MINERU_API_TIMEOUT_SECONDS=300
MINERU_API_UPLOAD_TIMEOUT_SECONDS=600
SKIM_SCORE_THRESHOLD=0.65
# 本地开发默认来源；生产环境请改成公网域名或 IP，不建议使用 *
CORS_ALLOW_ORIGINS=http://127.0.0.1:3002,http://localhost:3002
USER_TIMEZONE=Asia/Shanghai
# 生产环境应关闭 API 文档；公网域名请显式写入 CORS_ALLOW_ORIGINS
EXPOSE_API_DOCS=true

# LLM Provider: openai / anthropic / zhipu / gemini
LLM_PROVIDER=zhipu

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic
ANTHROPIC_API_KEY=
# Gemini
GEMINI_API_KEY=
# ZhipuAI (智谱)
ZHIPU_API_KEY=

SEMANTIC_SCHOLAR_API_KEY=
# OpenAlex（高速率引用源，填邮箱即可获得 10 req/s 免费配额）
OPENALEX_EMAIL=

LLM_MODEL_SKIM=glm-4.7
LLM_MODEL_DEEP=glm-4.7
LLM_MODEL_VISION=glm-4.6v
LLM_MODEL_FALLBACK=glm-4.7
# 推理链专用：限制文本页数 / 输出长度 / 单次 LLM 超时
REASONING_MAX_PAGES=10
REASONING_MAX_TOKENS=4096
REASONING_LLM_TIMEOUT_SECONDS=150
EMBEDDING_MODEL=embedding-3
# 可选：独立嵌入配置（留空则沿用主 LLM 提供方 / Key / Base URL）
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=

# 可选：独立绘图配置（用于写作助手中的 Gemini Nano Banana 图像生成）
IMAGE_PROVIDER=
IMAGE_API_KEY=
IMAGE_API_BASE_URL=
IMAGE_MODEL=gemini-2.5-flash-image

COST_GUARD_ENABLED=true
PER_CALL_BUDGET_USD=0.05
DAILY_BUDGET_USD=2.0

# ==========================================
# 站点认证配置
# ==========================================

# 站点密码，为空则禁用认证（仅建议本地开发）
# 非 dev 环境若未启用认证，必须显式 ALLOW_UNAUTHENTICATED=true
AUTH_PASSWORD=

# 推荐生产环境使用 bcrypt 哈希，不要直接配置明文密码
AUTH_PASSWORD_HASH=

# JWT 密钥（用于签名 token）
# 生产环境请修改为随机字符串
AUTH_SECRET_KEY=

# 非 dev 环境是否允许无认证启动；公网部署保持 false
ALLOW_UNAUTHENTICATED=false

# ==========================================
# SMTP 邮件配置
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_DEFAULT_TO=

# ==========================================
# 智能调度配置 - UTC 时间（推荐）
# ==========================================

# 每日简报时间（UTC 时间）
# 推荐：0 4 * * * (UTC 4 点 = 北京时间 12 点，午饭时间)
# 说明：预留 2 小时处理缓冲
#       02:00 主题抓取 → 02:00-04:00 并行处理 → 04:00 生成简报
DAILY_CRON=0 4 * * *

# 首页 arXiv 趋势预计算（UTC 16 点 = 北京时间 00 点）
DASHBOARD_TREND_CRON=0 16 * * *

# 首次打开主页时若没有趋势快照，允许 API 直接按需生成。
# 源码开发和 exe 桌面版建议开启，公网部署可改为 false 并依赖 worker 定时预计算。
RESEARCHOS_DASHBOARD_TREND_ON_DEMAND=true

# 每周图谱维护（UTC 时间）
# 推荐：0 22 * * 0 (UTC 周日 22 点 = 北京时间周一 6 点)
WEEKLY_CRON=0 22 * * 0

# 主题抓取默认时间（UTC 小时，0-23）
# 推荐：2 (UTC 2 点 = 北京时间 10 点)
DEFAULT_TOPIC_TIME_UTC=2

# 精读配额配置（每个主题每次最多精读篇数）
# 推荐：20 篇抓取 → 精读 1-3 篇（节省 LLM 费用）
DEFAULT_MAX_DEEP_READS=2

# ==========================================
# 闲时自动处理器配置
# ==========================================

# 是否启用闲时自动处理（true/false）
# 功能：系统空闲时自动批量处理未读论文（只粗读 + 嵌入，不精读）
IDLE_PROCESSOR_ENABLED=true

# 闲时批次处理数量（每次处理几篇）
# 推荐：5-10 篇（避免影响正常用户请求）
IDLE_BATCH_SIZE=5

# 空闲检测间隔（秒）
# 推荐：60 秒（每分钟检测一次）
IDLE_CHECK_INTERVAL=60

# 系统空闲阈值（用于闲时检测）
# CPU 使用率低于此值才认为是空闲
IDLE_CPU_THRESHOLD=30.0

# 内存使用率低于此值才认为是空闲
IDLE_MEMORY_THRESHOLD=70.0

# API 请求数低于此值才认为是空闲（请求数/分钟）
IDLE_REQUEST_THRESHOLD=5

# ==========================================
# Worker 重试配置
# ==========================================

# 任务失败最大重试次数
WORKER_RETRY_MAX=3

# 重试基础延迟（秒），使用指数退避
WORKER_RETRY_BASE_DELAY=5.0

# ==========================================
# Agent / 工作区执行配置
# ==========================================
AGENT_MAX_TOOL_STEPS=20
AGENT_COMPACTION_AUTO=true
AGENT_COMPACTION_RESERVED_TOKENS=20000
AGENT_COMPACTION_FALLBACK_CONTEXT_WINDOW=128000
AGENT_RETRY_MAX_ATTEMPTS=2
PAPER_CONCURRENCY=5
BRIEF_CACHE_TTL=300

# ==========================================
# OpenCode / Codex-compatible 后端（可选）
# ==========================================
OPENCODE_PROVIDER=openai
OPENCODE_API_KEY=
OPENCODE_BASE_URL=
OPENCODE_MODEL=
OPENCODE_SMALL_MODEL=
